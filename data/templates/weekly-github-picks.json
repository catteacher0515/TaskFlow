{
  "id": "weekly-github-picks",
  "name": "每周 GitHub 精选",
  "description": "按候选亲测、推荐收敛、成稿和多平台发布的方式推进一轮每周 GitHub 精选。",
  "stages": [],
  "slots": [],
  "minimumActions": [
    {
      "id": "review-one-repo",
      "label": "处理 1 个候选仓库"
    },
    {
      "id": "select-one-repo",
      "label": "确认 1 个入选仓库"
    },
    {
      "id": "finish-one-platform",
      "label": "完成 1 个发布平台"
    }
  ],
  "recurrence": {
    "supportedRules": [
      "none",
      "daily",
      "weekly",
      "monthly",
      "workdays",
      "custom_interval"
    ],
    "defaultRule": {
      "kind": "weekly"
    }
  },
  "warningRules": {
    "parallelLimit": {
      "useGlobalLimit": true
    },
    "stagnation": {
      "daysWithoutActivity": 2
    }
  }
}
